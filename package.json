{
  "name": "barrington-mtg-collection",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build-seed": "node scripts/build-seed.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create mtg-collection",
    "db:schema:local": "wrangler d1 execute mtg-collection --local --file=./schema.sql",
    "db:seed:local": "wrangler d1 execute mtg-collection --local --file=./seed.sql",
    "db:schema": "wrangler d1 execute mtg-collection --remote --file=./schema.sql",
    "db:seed": "wrangler d1 execute mtg-collection --remote --file=./seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
